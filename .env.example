# Workspace where Claude operates (cwd for spawned agent)
# Defaults to the aios-bridge dir itself if unset.
WORKSPACE_DIR=

# Adapter: claude-code (default) | opencode | ollama | failover
AGENT_ADAPTER=claude-code

# Failover chain (only when AGENT_ADAPTER=failover). Tried in order until
# one succeeds. Lets the bridge survive Claude outages / cap hits.
# AGENT_FAILOVER_CHAIN=claude-code,opencode,ollama

# Claude Code path override. Auto-detected on macOS/Linux/Windows if unset.
# CLAUDE_CMD=/usr/local/bin/claude

# opencode path override (auto-detected if on PATH).
# OPENCODE_CMD=/usr/local/bin/opencode

# Ollama (local model fallback).
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5-coder:14b

# Tools claude is allowed to use (comma-separated, MCP servers as mcp__<name>)
ALLOWED_TOOLS=Read,Write,Edit,MultiEdit,NotebookEdit,Bash,Glob,Grep,WebFetch,WebSearch,TodoWrite

# OAuth keepalive interval (ms). 20min = 1200000. Set 0 to disable.
OAUTH_KEEPALIVE_MS=1200000

# Per-message timeout (ms). 10min default.
AGENT_TIMEOUT_MS=600000
